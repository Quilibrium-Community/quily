READY TO MIGRATE TO BWS - 27-04-2026

# Quily Chatbot - Environment Configuration
# Copy to `.env.local` and fill in your values.

# ──────────────────────────────────────────
# FREE MODE (uses server's OPENROUTER_API_KEY for all users)
# When enabled, users skip setup and chat for free using the server key.
# Requires OPENROUTER_API_KEY to be set above.
# If credits run out, falls back to asking users for their own provider.
# Optional: override the default model (defaults to deepseek/deepseek-v4-flash)
# ──────────────────────────────────────────
NEXT_PUBLIC_FREE_MODE=true
# FREE_MODE_DEFAULT_MODEL=deepseek/deepseek-v4-flash
# NEXT_PUBLIC_FREE_MODE_DEFAULT_MODEL=deepseek/deepseek-v4-flash  # must match FREE_MODE_DEFAULT_MODEL

# ──────────────────────────────────────────
# SUPABASE (required)
# Get from: https://supabase.com/dashboard → Settings → API
# ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Legacy aliases for ingestion scripts
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ---------------------------------------------
# LLM PROVIDERS
# ---------------------------------------------

# OPENROUTER (required for ingestion, optional for chat if using Chutes)

OPENROUTER_API_KEY=

# Zero Data Retention: when "true", OpenRouter routes chat requests only to
# providers that do NOT retain prompts (privacy). Applies to the web chat and
# Discord bot. deepseek-v4-flash has ZDR-capable providers, so enabling this
# won't cause "no providers available". Flip without code changes.
OPENROUTER_ZDR=true

# CHUTES (optional - alternative to OpenRouter for chat)
# Register OAuth app at: https://chutes.ai

CHUTES_OAUTH_CLIENT_ID=
CHUTES_OAUTH_CLIENT_SECRET=
CHUTES_OAUTH_SCOPES="profile chutes:read chutes:invoke"
# API key for model discovery (OAuth tokens can't list models)
CHUTES_API_KEY=

# Optional overrides
# NEXT_PUBLIC_CHUTES_ENABLED=true
# CHUTES_OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/chutes/callback
# CHUTES_IDP_BASE_URL=https://api.chutes.ai
# CHUTES_DEFAULT_MODEL=https://your-llm-chute.chutes.ai
# CHUTES_EMBEDDING_MODEL=https://embeddings.chutes.ai

# ---------------------------------------------
# OTHER SERVICES
# ---------------------------------------------

# GitHub token for docs sync (increases rate limit from 60 to 5000/hour)
# Get from: https://github.com/settings/tokens (no scopes needed)
GITHUB_TOKEN=

# RAG Enhancement (optional - improves search quality)
# COHERE_API_KEY=your_cohere_api_key

# ---------------------------------------------
# CHAT LATENCY TUNING (optional - sensible defaults baked into code)
# See .agents/docs/chat-latency-pipeline.md
# ---------------------------------------------

# LLM provider routing on the web chat path. Default 'latency' picks the fastest
# provider (cuts time-to-first-token ~2-3x) while a code-side quantization allowlist
# excludes fp4 backends. Set to "" to disable the sort and use OpenRouter default routing.
# OPENROUTER_SORT=latency

# Provider order for the query embedding (baai/bge-m3). Pinning avoids OpenRouter
# routing to a slow provider on every request. Comma-separated; set "" to disable.
# The model is deterministic so pinning does not change retrieval results.
# OPENROUTER_EMBED_ORDER=SiliconFlow,DeepInfra

# ---------------------------------------------
# APPLICATION SETTINGS
# ---------------------------------------------

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature flags
NEXT_PUBLIC_CHUTES_ENABLED=true

# Long random secret. When set, /api/chat accepts ?debug=<token> (or x-debug-token
# header) to skip Turnstile and stream `data-debug` SSE events with diagnostics.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Used by `yarn prod-curl` for autonomous prod debugging. Must match the value in
# Vercel production env. See .agents/docs/production-debug-pipeline.md.
DEBUG_BYPASS_TOKEN=

# ---------------------------------------------
# CLOUDFARE
# ---------------------------------------------

# Cloudflare Workers AI reranking (FREE - 10k neurons/day)
# Get from: https://dash.cloudflare.com/ → Workers & Pages → Overview (Account ID in sidebar)
# API Token: My Profile → API Tokens → Create Token → Workers AI Read permission
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Cloudflare Turnstile (bot protection)
# Get from: https://dash.cloudflare.com/ → Turnstile → Add Widget
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------------------------------------------
# Discord
# ---------------------------------------------
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CHANNEL_IDS=1212447064861184060:announcements,1421639566841876510:dev-updates

# ──────────────────────────────────────────
# DAILY DIGEST (multi-channel — posts a daily summary to one destination)
# ──────────────────────────────────────────
# Comma-separated source channels to summarize (order = display order in digest)
DISCORD_DIGEST_CHANNEL_IDS=1212446222367985726,1212447064861184060,1421639566841876510
# Destination channel where the compiled digest is posted (e.g. #daily-digest)
DISCORD_RECAP_CHANNEL_ID=
# UTC hour to post (default: 14)
#DISCORD_RECAP_HOUR=14
# Legacy single-channel fallback (used only if DISCORD_DIGEST_CHANNEL_IDS is unset)
DISCORD_GENERAL_CHANNEL_ID=1212446222367985726
# OpenRouter model for summarization (default: deepseek/deepseek-v4-flash)
#RECAP_LLM_MODEL=

# ──────────────────────────────────────────
# BUG REPORTS DIGEST (dedicated triage — runs right after the main digest)
# ──────────────────────────────────────────
DISCORD_BUG_REPORTS_CHANNEL_ID=1456158029627129961
# Where to post the digest (default: same channel as source, i.e. the bug-reports channel)
#DISCORD_BUG_REPORTS_POST_CHANNEL_ID=
# UTC hour to post (default: 7 — early so the lead dev sees it at start of day)
#BUG_DIGEST_HOUR=7
# Triage model (default: deepseek/deepseek-v4-flash)
#BUG_TRIAGE_LLM_MODEL=
# Vision model for image attachments (default: google/gemini-2.5-flash-lite)
#BUG_TRIAGE_VISION_MODEL=
